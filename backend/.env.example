# ── Database ──────────────────────────────────────────────────────────────
# Local dev — PostgreSQL via docker-compose:
#   docker-compose up -d
#   then: npx prisma db push && npx ts-node src/prisma/seed.ts
DATABASE_URL="postgresql://leafpal:leafpal_dev@localhost:5432/leafpal"

# Railway production — Railway dashboard'dan PostgreSQL plugin ekle,
# DATABASE_URL otomatik set edilir.

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-long-random-string"

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Dev helpers ───────────────────────────────────────────────────────────
# Set true to bypass JWT auth (uses dev-user-id). PRODUCTION'DA ASLA true.
SKIP_AUTH=true

# ── Plant Identification API ──────────────────────────────────────────────
# Get your key from: https://my.plantnet.org/
# Leave empty to use mock data.
PLANT_API_KEY=""
